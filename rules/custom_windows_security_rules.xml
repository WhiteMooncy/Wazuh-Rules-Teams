    <mitre>
      <id>T1543.003</id>
      <id>T1569.002</id>
    </mitre>
    <group>system_configuration,attack,pci_dss_10.2.7,gdpr_IV_35.7.d,hipaa_164.312.b,nist_800_53_AU.6,tsc_CC6.1,tsc_CC6.8,</group>
  </rule>

  <!--  EXPLICIT LOGON - LATERAL MOVEMENT  -->
  
  <!-- Event 4648: Logon using explicit credentials -->
  <rule id="100009" level="5">
    <if_sid>60103</if_sid>
