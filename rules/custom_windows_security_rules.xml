  <rule id="100012" level="12">
    <if_matched_sid>100011</if_matched_sid>
    <field name="win.eventdata.newProcessName">powershell\.exe|cmd\.exe|wscript\.exe|cscript\.exe</field>
    <field name="win.eventdata.parentProcessName">winword\.exe|excel\.exe|outlook\.exe|acrobat\.exe</field>
