      <id>T1543.003</id>
    </mitre>
    <group>system_configuration,pci_dss_10.2.7,pci_dss_10.6.1,gdpr_IV_35.7.d,hipaa_164.312.b,nist_800_53_AU.6,nist_800_53_AU.14,tsc_CC6.8,tsc_CC7.2,tsc_CC7.3,</group>
  </rule>

  <rule id="100008" level="12">
    <if_matched_sid>100007</if_matched_sid>
    <field name="win.eventdata.serviceName">\..*psexec|\..*mimikatz|\..*meterpreter|\..*cobalt</field>
