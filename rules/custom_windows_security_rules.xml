<!--
  -  Custom Windows Security Rules para Wazuh
  -  Autor: SOC
  -  Fecha: 2026-03-11
  -  
  -  Descripción: Reglas custom para eventos críticos de Windows Security
  -  que no están cubiertos en las reglas base de Wazuh o necesitan
  -  ajuste de nivel de severidad.
  -  
  -  CATEGORÍAS INCLUIDAS:
  -  - Kerberos Authentication (ALTA PRIORIDAD)
  -  - Service Installation (ALTA PRIORIDAD)
  -  - Process Creation (ALTA PRIORIDAD)
  -  - AD Federation Services (MEDIA PRIORIDAD)
  -  - Scheduled Tasks (MEDIA PRIORIDAD)
  -  - Policy Changes (MEDIA PRIORIDAD)
  -  - Privilege Use (MEDIA PRIORIDAD)
  -  - LSASS Events (MEDIA PRIORIDAD)
  -  - Object Access (MEDIA PRIORIDAD)
  -->

<group name="windows,sysmon,">

  <!--  REGLAS CRÍTICAS - PRIORIDAD ALTA  -->
  <!--  KERBEROS AUTHENTICATION  -->
  
  <!-- Event 4768: Kerberos TGT Request -->
  <rule id="100001" level="3">
    <if_sid>60103</if_sid>
    <field name="win.system.eventID">^4768$</field>
    <description>Windows: Solicitud de servicio de autenticación Kerberos (TGT) | Kerberos Authentication Service (TGT) requested</description>
    <mitre>
      <id>T1558.003</id>
    </mitre>
    <group>authentication_success,pci_dss_10.2.5,gdpr_IV_32.2,hipaa_164.312.b,nist_800_53_AU.14,nist_800_53_AC.7,tsc_CC6.8,tsc_CC7.2,tsc_CC7.3,</group>
  </rule>

  <rule id="100002" level="10" frequency="10" timeframe="120">
    <if_matched_sid>100001</if_matched_sid>
    <same_source_ip />
    <description>Windows: Posible ataque Kerberoasting - Múltiples solicitudes TGT desde la misma IP | Possible Kerberoasting attack - Multiple TGT requests from same IP</description>
    <mitre>
      <id>T1558.003</id>
    </mitre>
    <group>authentication_failures,attack,pci_dss_11.4,gdpr_IV_35.7.d,nist_800_53_SI.4,tsc_CC6.1,tsc_CC6.8,tsc_CC7.2,tsc_CC7.3,</group>
  </rule>

  <rule id="100003" level="5">
    <if_sid>60103</if_sid>
    <field name="win.system.eventID">^4768$</field>
    <field name="win.eventdata.status">0x12</field>
    <description>Windows: Solicitud TGT Kerberos fallida - Cuenta deshabilitada o expirada | Kerberos TGT request failed - Account disabled or expired</description>
    <mitre>
      <id>T1078</id>
    </mitre>
    <group>authentication_failed,pci_dss_10.2.4,pci_dss_10.2.5,gdpr_IV_35.7.d,gdpr_IV_32.2,hipaa_164.312.b,nist_800_53_AU.14,nist_800_53_AC.7,tsc_CC6.1,tsc_CC6.8,tsc_CC7.2,tsc_CC7.3,</group>
  </rule>

  <!-- Event 4770: Kerberos Ticket Renewal -->
  <rule id="100004" level="3">
    <if_sid>60103</if_sid>
    <field name="win.system.eventID">^4770$</field>
    <description>Windows: Ticket de servicio Kerberos renovado | Kerberos service ticket renewed</description>
    <mitre>
      <id>T1558</id>
    </mitre>
    <group>authentication_success,pci_dss_10.2.5,gdpr_IV_32.2,hipaa_164.312.b,nist_800_53_AU.14,nist_800_53_AC.7,</group>
  </rule>

  <rule id="100005" level="8">
    <if_sid>60103</if_sid>
    <field name="win.system.eventID">^4770$</field>
    <field name="win.eventdata.status">0x1F</field>
    <description>Windows: Renovación de ticket Kerberos fallida - Falló verificación de integridad | Kerberos ticket renewal failed - Integrity check failed</description>
    <mitre>
      <id>T1558</id>
    </mitre>
    <group>authentication_failed,attack,pci_dss_10.2.4,gdpr_IV_35.7.d,nist_800_53_AU.14,tsc_CC6.1,tsc_CC6.8,tsc_CC7.2,tsc_CC7.3,</group>
  </rule>

  <!-- Event 4679: Kerberos Service Ticket -->
  <rule id="100006" level="3">
    <if_sid>60103</if_sid>
    <field name="win.system.eventID">^4679$</field>
