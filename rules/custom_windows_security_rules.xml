<group name="windows,sysmon,">

  <!--  REGLAS CRÍTICAS - PRIORIDAD ALTA  -->
  <!--  KERBEROS AUTHENTICATION  -->
  
  <!-- Event 4768: Kerberos TGT Request -->
  <rule id="100001" level="3">
    <if_sid>60100</if_sid>
    <field name="win.system.eventID">^4768$</field>
    <description>Windows: Solicitud de servicio de autenticación Kerberos (TGT) | Kerberos Authentication Service (TGT) requested</description>
    <mitre>
      <id>T1558.003</id>
    </mitre>
    <group>authentication_success,pci_dss_10.2.5,gdpr_IV_32.2,hipaa_164.312.b,nist_800_53_AU.14,nist_800_53_AC.7,tsc_CC6.8,tsc_CC7.2,tsc_CC7.3,</group>
  </rule>

  <rule id="100002" level="10" frequency="10" timeframe="120">
    <if_matched_sid>100001</if_matched_sid>
    <same_source_ip />
    <description>Windows: Posible ataque Kerberoasting - Múltiples solicitudes TGT desde la misma IP | Possible Kerberoasting attack - Multiple TGT requests from same IP</description>
    <mitre>
      <id>T1558.003</id>
    </mitre>
    <group>authentication_failures,attack,pci_dss_11.4,gdpr_IV_35.7.d,nist_800_53_SI.4,tsc_CC6.1,tsc_CC6.8,tsc_CC7.2,tsc_CC7.3,</group>
  </rule>

  <rule id="100003" level="5">
    <if_sid>60100</if_sid>
    <field name="win.system.eventID">^4768$</field>
    <field name="win.eventdata.status">0x12</field>
    <description>Windows: Solicitud TGT Kerberos fallida - Cuenta deshabilitada o expirada | Kerberos TGT request failed - Account disabled or expired</description>
    <mitre>
      <id>T1078</id>
    </mitre>
    <group>authentication_failed,pci_dss_10.2.4,pci_dss_10.2.5,gdpr_IV_35.7.d,gdpr_IV_32.2,hipaa_164.312.b,nist_800_53_AU.14,nist_800_53_AC.7,tsc_CC6.1,tsc_CC6.8,tsc_CC7.2,tsc_CC7.3,</group>
  </rule>

  <!-- Event 4770: Kerberos Ticket Renewal -->
  <rule id="100004" level="3">
    <if_sid>60100</if_sid>
    <field name="win.system.eventID">^4770$</field>
    <description>Windows: Ticket de servicio Kerberos renovado | Kerberos service ticket renewed</description>
    <mitre>
      <id>T1558</id>
    </mitre>
    <group>authentication_success,pci_dss_10.2.5,gdpr_IV_32.2,hipaa_164.312.b,nist_800_53_AU.14,nist_800_53_AC.7,</group>
  </rule>

  <rule id="100005" level="8">
    <if_sid>60100</if_sid>
    <field name="win.system.eventID">^4770$</field>
    <field name="win.eventdata.status">0x1F</field>
    <description>Windows: Renovación de ticket Kerberos fallida - Falló verificación de integridad | Kerberos ticket renewal failed - Integrity check failed</description>
    <mitre>
      <id>T1558</id>
    </mitre>
    <group>authentication_failed,attack,pci_dss_10.2.4,gdpr_IV_35.7.d,nist_800_53_AU.14,tsc_CC6.1,tsc_CC6.8,tsc_CC7.2,tsc_CC7.3,</group>
  </rule>

  <!-- Event 4679: Kerberos Service Ticket -->
  <rule id="100006" level="3">
    <if_sid>60100</if_sid>
    <field name="win.system.eventID">^4679$</field>
    <description>Windows: Operaciones de ticket de servicio Kerberos | Kerberos service ticket operations</description>
    <mitre>
      <id>T1558</id>
    </mitre>
    <group>authentication_success,pci_dss_10.2.5,gdpr_IV_32.2,</group>
  </rule>

  <!--  SERVICE INSTALLATION - CRÍTICO  -->
  
  <!-- Event 4697: Service Installed -->
  <rule id="100007" level="8">
    <if_sid>60100</if_sid>
    <field name="win.system.eventID">^4697$</field>
    <description>Windows: Un servicio fue instalado en el sistema | A service was installed in the system</description>
    <mitre>
      <id>T1543.003</id>
    </mitre>
    <group>system_configuration,pci_dss_10.2.7,pci_dss_10.6.1,gdpr_IV_35.7.d,hipaa_164.312.b,nist_800_53_AU.6,nist_800_53_AU.14,tsc_CC6.8,tsc_CC7.2,tsc_CC7.3,</group>
  </rule>

  <rule id="100008" level="12">
    <if_matched_sid>100007</if_matched_sid>
    <field name="win.eventdata.serviceName">\..*psexec|\..*mimikatz|\..*meterpreter|\..*cobalt</field>
    <description>Windows: Servicio sospechoso instalado - Posible movimiento lateral o malware | Suspicious service installed - Possible lateral movement or malware</description>
    <mitre>
      <id>T1543.003</id>
      <id>T1569.002</id>
    </mitre>
    <group>system_configuration,attack,pci_dss_10.2.7,gdpr_IV_35.7.d,hipaa_164.312.b,nist_800_53_AU.6,tsc_CC6.1,tsc_CC6.8,</group>
  </rule>

  <!--  EXPLICIT LOGON - LATERAL MOVEMENT  -->
  
  <!-- Event 4648: Logon using explicit credentials -->
  <rule id="100009" level="5">
    <if_sid>60100</if_sid>
    <field name="win.system.eventID">^4648$</field>
    <description>Windows: Intento de inicio de sesión usando credenciales explícitas | A logon was attempted using explicit credentials</description>
    <mitre>
      <id>T1078</id>
      <id>T1021</id>
    </mitre>
    <group>authentication_success,pci_dss_10.2.5,gdpr_IV_32.2,hipaa_164.312.b,nist_800_53_AU.14,tsc_CC6.8,tsc_CC7.2,tsc_CC7.3,</group>
  </rule>

  <rule id="100010" level="10" frequency="8" timeframe="120">
    <if_matched_sid>100009</if_matched_sid>
    <same_source_ip />
    <description>Windows: Múltiples inicios de sesión con credenciales explícitas desde mismo origen - Posible movimiento lateral | Multiple explicit credential logons from same source - Possible lateral movement</description>
    <mitre>
      <id>T1078</id>
      <id>T1021.002</id>
    </mitre>
    <group>authentication_success,attack,pci_dss_10.2.5,gdpr_IV_35.7.d,nist_800_53_AU.14,tsc_CC6.1,tsc_CC6.8,</group>
  </rule>

  <!--  PROCESS CREATION  -->
  
  <!-- Event 4688: New Process Created -->
  <rule id="100011" level="3">
    <if_sid>60100</if_sid>
    <field name="win.system.eventID">^4688$</field>
    <description>Windows: Un nuevo proceso ha sido creado | A new process has been created</description>
    <mitre>
      <id>T1106</id>
    </mitre>
    <group>process_creation,pci_dss_10.2.7,gdpr_IV_35.7.d,hipaa_164.312.b,nist_800_53_AU.14,</group>
  </rule>

  <rule id="100012" level="12">
    <if_matched_sid>100011</if_matched_sid>
    <field name="win.eventdata.newProcessName">powershell\.exe|cmd\.exe|wscript\.exe|cscript\.exe</field>
    <field name="win.eventdata.parentProcessName">winword\.exe|excel\.exe|outlook\.exe|acrobat\.exe</field>
    <description>Windows: Creación de proceso sospechoso - Office ejecutó intérprete de scripts | Suspicious process creation - Office spawned script interpreter</description>
    <mitre>
      <id>T1059.001</id>
      <id>T1059.003</id>
      <id>T1566.001</id>
    </mitre>
    <group>process_creation,attack,pci_dss_10.6.1,gdpr_IV_35.7.d,hipaa_164.312.b,nist_800_53_AU.6,tsc_CC6.1,tsc_CC6.8,tsc_CC7.2,</group>
  </rule>

  <rule id="100013" level="10">
    <if_matched_sid>100011</if_matched_sid>
    <field name="win.eventdata.commandLine">-enc|-encodedcommand|-nop|-noni|bypass|invoke-expression|downloadstring</field>
    <description>Windows: Línea de comandos PowerShell sospechosa - Posible malware o ataque de script | Suspicious PowerShell command line - Possible malware or script attack</description>
    <mitre>
      <id>T1059.001</id>
      <id>T1027</id>
    </mitre>
    <group>process_creation,attack,pci_dss_10.6.1,gdpr_IV_35.7.d,nist_800_53_AU.6,tsc_CC6.1,tsc_CC6.8,tsc_CC7.2,</group>
  </rule>

  <!-- Event 4689: Process Terminated -->
  <rule id="100014" level="2">
    <if_sid>60100</if_sid>
    <field name="win.system.eventID">^4689$</field>
    <description>Windows: Un proceso ha finalizado | A process has exited</description>
    <group>process_termination,</group>
  </rule>

  <!-- Event 4690-4696: Token Manipulation -->
  <rule id="100015" level="6">
    <if_sid>60100</if_sid>
    <field name="win.system.eventID">^469[0-6]$</field>
    <description>Windows: Manipulación de Token/Handle detectada | Token/Handle manipulation detected</description>
    <mitre>
      <id>T1134</id>
    </mitre>
    <group>privilege_escalation,pci_dss_10.2.5,gdpr_IV_35.7.d,hipaa_164.312.b,nist_800_53_AU.14,tsc_CC6.8,tsc_CC7.2,</group>
  </rule>

  <!--  OBJECT ACCESS  -->
  
  <!-- Event 4663: Object Access Attempt -->
  <rule id="100016" level="2">
    <if_sid>60100</if_sid>
    <field name="win.system.eventID">^4663$</field>
    <description>Windows: Se intentó acceder a un objeto | An attempt was made to access an object</description>
    <group>object_access,pci_dss_10.2.5,gdpr_IV_32.2,</group>
  </rule>

  <rule id="100017" level="8">
    <if_matched_sid>100016</if_matched_sid>
    <field name="win.eventdata.objectName">\\lsass\.exe|\\SAM|\\SYSTEM|\\SECURITY</field>
    <description>Windows: Objeto sensible accedido - Posible volcado de credenciales | Sensitive object accessed - Possible credential dumping</description>
    <mitre>
      <id>T1003.001</id>
      <id>T1003.002</id>
    </mitre>
    <group>object_access,attack,pci_dss_10.6.1,gdpr_IV_35.7.d,nist_800_53_AU.6,tsc_CC6.1,tsc_CC6.8,</group>
  </rule>

