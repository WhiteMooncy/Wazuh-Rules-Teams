  <!--  SERVICE INSTALLATION - CRÍTICO  -->
  
  <!-- Event 4697: Service Installed -->
  <rule id="100007" level="8">
    <if_sid>60103</if_sid>
    <field name="win.system.eventID">^4697$</field>
    <description>Windows: Un servicio fue instalado en el sistema | A service was installed in the system</description>
