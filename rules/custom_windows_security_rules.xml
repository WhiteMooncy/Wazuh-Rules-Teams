    <mitre>
      <id>T1059.001</id>
      <id>T1059.003</id>
      <id>T1566.001</id>
    </mitre>
    <group>process_creation,attack,pci_dss_10.6.1,gdpr_IV_35.7.d,hipaa_164.312.b,nist_800_53_AU.6,tsc_CC6.1,tsc_CC6.8,tsc_CC7.2,</group>
  </rule>

  <rule id="100013" level="10">
