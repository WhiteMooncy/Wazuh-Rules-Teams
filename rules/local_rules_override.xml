<!--
  -  Local Rules Override para Wazuh
  -  Autor: SOC
  -  Fecha: 2026-03-11
  -  
  -  Descripción: Override rules para modificar el nivel de severidad de 
  -  reglas existentes de Wazuh que tienen configuración subóptima.
  -  
  -  NOTA: El atributo overwrite="yes" indica que esta regla reemplaza
  -  completamente la regla original con el mismo ID.
  -
  - Example 
  -<group name="local,syslog,sshd,">
  -  Dec 10 01:02:02 host sshd[1234]: Failed none for root from 1.1.1.1 port 1066 ssh2
  -  <rule id="100001" level="5">
  -    <if_sid>5716</if_sid>
  -    <srcip>1.1.1.1</srcip>
  -    <description>sshd: authentication failed from IP 1.1.1.1.</description>
  -    <group>authentication_failed,pci_dss_10.2.4,pci_dss_10.2.5,</group>
  -  </rule>
  -</group>
  -->

<group name="windows,">
 
  <!--  AJUSTES DE NIVEL CRÍTICOS   -->
 
  <rule id="60103" level="8" overwrite="yes">
    <if_sid>60100</if_sid>
    <field name="win.system.eventID">^4724$</field>
    <description>Windows: Se intentó restablecer la contraseña de una cuenta | An attempt was made to reset an account's password</description>
    <mitre>
      <id>T1098</id>
    </mitre>
    <group>account_changed,pci_dss_10.2.5,pci_dss_8.2.3,gdpr_IV_35.7.d,gdpr_IV_32.2,hipaa_164.312.b,hipaa_164.312.d,nist_800_53_AU.14,nist_800_53_AC.2,tsc_CC6.8,tsc_CC7.2,tsc_CC7.3,</group>
  </rule>

  <!--
    Regla personalizada para Detectar múltiples resets de password en corto tiempo
  -->
  <rule id="100070" level="12" frequency="5" timeframe="300">
    <if_matched_sid>60103</if_matched_sid>
    <same_source_ip />
    <description>Windows: Múltiples restablecimientos de contraseña desde mismo origen - Posible ataque | Multiple password resets from same source - Possible attack</description>
    <mitre>
      <id>T1098</id>
      <id>T1110</id>
    </mitre>
    <group>account_changed,attack,pci_dss_10.6.1,gdpr_IV_35.7.d,hipaa_164.312.b,nist_800_53_AU.6,tsc_CC6.1,tsc_CC6.8,tsc_CC7.2,tsc_CC7.3,</group>
  </rule>

  <!--
    Regla personalizada para Password reset fuera de horario laboral
  -->
  <rule id="100071" level="10">
    <if_matched_sid>60103</if_matched_sid>
    <time>6 pm - 6 am</time>
    <description>Windows: Restablecimiento de contraseña fuera de horario laboral - Actividad sospechosa | Password reset outside business hours - Suspicious activity</description>
    <mitre>
      <id>T1098</id>
    </mitre>
    <group>account_changed,after_hours,pci_dss_10.6.1,gdpr_IV_35.7.d,nist_800_53_AU.6,tsc_CC6.1,tsc_CC6.8,</group>
  </rule>

  <!--
    Regla personalizada para Password reset de cuenta privilegiada
  -->
  <rule id="100072" level="12">
    <if_matched_sid>60103</if_matched_sid>
    <field name="win.eventdata.targetUserName">admin|administrator|root|domainadmin|enterpriseadmin</field>
    <description>Windows: Restablecimiento de contraseña de cuenta privilegiada - Evento crítico | Password reset of privileged account - Critical event</description>
    <mitre>
      <id>T1098</id>
      <id>T1078.002</id>
    </mitre>
    <group>account_changed,privileged_account,pci_dss_10.2.5,gdpr_IV_35.7.d,hipaa_164.312.b,nist_800_53_AU.14,tsc_CC6.1,tsc_CC6.8,tsc_CC7.2,tsc_CC7.3,</group>
  </rule>
</group>

  <!--
    Regla personalizada para eliminación de audit log de Windows
  -->
<group name="windows,windows_logs,log_clearing_auditlog,attack.defense_evasion,">
  
  <rule id="100101" level="15">
    <if_sid>60000</if_sid>
    <field name="win.system.eventID">^1102$</field>
    <description>ALERTA CRÍTICA: Registro de seguridad eliminado por el usuario: $(win.logFileCleared.subjectUserName) | Dominio: $(win.logFileCleared.subjectDomainName)</description>
    <options>no_full_log</options>
    <group>log_clearing,pci_dss_10.5.2,gdpr_IV_35.7.d,hipaa_164.312.b,nist_800_53_AU.6,tsc_CC6.1,tsc_CC7.2,tsc_CC7.3,</group>
    <mitre>
      <id>T1070.001</id>
      <id>T1070</id>
    </mitre>
  </rule>

</group>

<!-- Regla para sesiones PAM de root -->
<group name="pam,syslog,authentication_success,">

  <rule id="100103" level="9">
    <if_sid>5501,5502</if_sid>
    <match>session opened for user root</match>
    <description>Linux: Sesión de usuario ROOT iniciada (PAM) - Nivel de alerta elevado para auditoría crítica | User session opened (PAM) - Elevated alert level for critical audit (ROOT)</description>
    <group>pci_dss_10.2.5,gpg13_7.8,gdpr_IV_32.2,hipaa_164.312.b,nist_800_53_AU.14,nist_800_53_AC.7,tsc_CC6.8,tsc_CC7.2,tsc_CC7.3,</group>
    <mitre>
      <id>T1078.003</id>
    </mitre>
  </rule>

</group>
