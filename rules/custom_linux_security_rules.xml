<!--
  -  Custom Linux Security Rules para Wazuh
  -  Autor: SOC
  -  Fecha: 2026-03-12
  -  
  -  Descripción: Reglas custom para eventos de seguridad Linux/Unix
  -  incluyendo autenticación SSH, PAM, y cuentas no-nominales.
  -  
  -  REGLAS INCLUIDAS:
  -  - 100103: Sesiones PAM de usuario ROOT
  -  - 200001: SSH failed login con cuenta no-nominal (Linux) - Nivel 11
  -  - 200002: Windows logon con cuenta no-nominal - Nivel 12
  -  - 200003: SSH authentication failed desde IP de documentación
  -  - 200004: CRÍTICO - Múltiples failed logins SSH con cuentas no-nominales (Frecuencia: 5 en 120s)
  -  - 200005: CRÍTICO - Múltiples logins Windows con cuentas no-nominales (Frecuencia: 5 en 120s)
  -  - 200006: SSH successful login con cuenta NOMINAL (usuarios legítimos) - Nivel 3
  -  
  -  DEPENDENCIAS:
  -  - CDB List: /etc/lists/no-nominal-account
  -->

<!--  SESIONES PAM - ROOT  -->

<group name="pam,syslog,authentication_success,">

  <rule id="100103" level="9">
    <if_sid>5501,5502</if_sid>
    <match>session opened for user root</match>
    <description>Linux: Sesión de usuario ROOT iniciada (PAM) - Nivel de alerta elevado para auditoría crítica | User session opened (PAM) - Elevated alert level for critical audit (ROOT)</description>
    <group>pci_dss_10.2.5,gpg13_7.8,gdpr_IV_32.2,hipaa_164.312.b,nist_800_53_AU.14,nist_800_53_AC.7,tsc_CC6.8,tsc_CC7.2,tsc_CC7.3,</group>
    <mitre>
      <id>T1078.003</id>
    </mitre>
  </rule>

</group>

<!--  AUTENTICACIÓN SSH  -->

<group name="local,syslog,sshd,">

  <!-- SSH failed login attempt con cuenta no-nominal -->
  <rule id="200001" level="11">
    <if_sid>5716, 5760</if_sid>
    <list field="user" lookup="match_key">etc/lists/no-nominal-account</list>
    <description>sshd: failed login attempt with non-nominal account $(user)</description>
    <mitre>
      <id>T1078.003</id>
      <id>T1110</id>
    </mitre>
  </rule>

  <!-- SSH authentication failed desde IP de documentación -->
  <rule id="200003" level="5">
    <if_sid>5716</if_sid>
    <srcip>192.0.2.10</srcip>
    <description>sshd: authentication failed from documentation IP 192.0.2.10.</description>
    <group>authentication_failed,pci_dss_10.2.4,pci_dss_10.2.5,</group>
  </rule>

  <!-- CORRELACIÓN: Múltiples intentos de login con cuentas no-nominales (SSH) -->
  <rule id="200004" level="15" frequency="5" timeframe="120">
    <if_matched_sid>200001</if_matched_sid>
    <same_source_ip />
    <description>CRITICAL: Multiple SSH logins detected with non-nominal accounts from same IP ($(srcip)) - Possible brute force attack</description>
    <group>authentication_failures,attack,</group>
    <mitre>
      <id>T1110</id>
      <id>T1078.003</id>
    </mitre>
  </rule>

  <!-- SSH successful login con cuenta NOMINAL (usuarios normales) -->
  <rule id="200006" level="3">
    <if_sid>5715</if_sid>
    <list field="user" lookup="not_match_key">etc/lists/no-nominal-account</list>
    <description>sshd: successful login with nominal account $(user)</description>
    <group>authentication_success,pci_dss_10.2.5,</group>
    <mitre>
      <id>T1078</id>
    </mitre>
  </rule>

</group>

<!--  WINDOWS LOGON CON CUENTAS NO-NOMINALES  -->

<group name="local,windows,">
  
  <rule id="200002" level="12">
    <if_sid>60106</if_sid>
    <list field="win.eventdata.targetUserName">etc/lists/no-nominal-account</list>
    <description>Windows logon with a no-nominal account "$(win.eventdata.targetUserName)"</description>
    <mitre>
      <id>T1078.003</id>
    </mitre>
  </rule>

  <!-- CORRELACIÓN: Múltiples intentos de login con cuentas no-nominales (Windows) -->
  <rule id="200005" level="15" frequency="5" timeframe="120">
    <if_matched_sid>200002</if_matched_sid>
    <same_source_ip />
    <description>CRITICAL: Multiple Windows logins detected with non-nominal accounts from same IP ($(srcip)) - Possible brute force attack</description>
    <group>authentication_failures,attack,</group>
    <mitre>
      <id>T1110</id>
      <id>T1078.003</id>
    </mitre>
  </rule>

</group>
